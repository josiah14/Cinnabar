#!/usr/bin/env bash
set -euo pipefail

# exit code meanings:
# 0 = all tests succeeded
# 1 = start_bang compiled but did not match expected output, start_explicit succeeded
# 3 = start_bang succeeded, start_explicit compiled but did not match expected output
# 4 = start_bang and start_explicit both compiled, but both did not match expected output.
# -5 = start_bang failed to compile, start_explicit succeeded
# -9 = start_bang compiled but did not match expected output, start_explicit failed to compile
# -10 = start_bang succeeded, start_explicit failed to compile
# -15 = start_bang and start_explicit both failed to compile
EXIT_CODE=0
echo "=== Compiling the !IO bang version..."
mmc --make --grade asm_fast.par.gc.stseg start_bang 2>&1 || { echo "COMPILE FAILED"; EXIT_CODE=-5; }
echo "=== Running the !IO bang version..."
output=$(./start_bang 2>&1)
echo "$output"

expected="Hello, World!
Hello, Mercury!!
IO token threaded: write_string 2
IO token threaded: write_string 3"

echo ""
if [ "$output" = "$expected" ]; then
    echo "Bang tests PASSED."
else
    echo "FAIL: output does not match the expected four lines."
    echo "--- actual ---"
    echo "$output"
    echo "--- expected ---"
    echo "$expected"
    EXIT_CODE=1
fi

echo "=== Compiling the explicit threading version..."
mmc --make --grade asm_fast.par.gc.stseg start_explicit 2>&1 || { echo "COMPILE FAILED"; EXIT_CODE=$((EXIT_CODE - 10)); }
echo "=== Running the explicit threading version..."
output=$(./start_explicit 2>&1)
echo "$output"

expected="Hello, World!
Hello, Mercury!!
IO token threaded: write_string 2
IO token threaded: write_string 3"

echo ""
if [ "$output" = "$expected" ]; then
    echo "Explicit tests PASSED."
else
    echo "FAIL: output does not match the expected four lines."
    echo "--- actual ---"
    echo "$output"
    echo "--- expected ---"
    echo "$expected"
    EXIT_CODE=$((EXIT_CODE + 3))
fi

exit $EXIT_CODE

