# mmc intermediate build directory (C output, object files, dep files)
Mercury/

# direnv / nix-direnv local environment cache (not part of the curriculum)
.direnv/

# mmc-generated Mercury interface headers
*.mh

# mmc error log (usually empty on success, never meaningful to track)
*.err
# Track koan diagnostic snapshots (needed by ci.sh compile_fail)
!**/*_koan.err

# mmc-generated C source, init files, and object files (may land in source dir
# depending on how mmc is invoked, not just inside Mercury/)
*_init.c
*_init.o
*.c_date
*.d
*.o
# Generated C from start.m (kata convention: all starters named start.m)
start.c
# Generated C from solution/fixed.m
fixed.c

